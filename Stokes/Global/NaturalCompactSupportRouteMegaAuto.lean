end NaturalCompactSupportRouteMegaBase

/--
Mega compact-support input for the exterior-derivative constructor route.

The raw common data, chart alignment, selected strict margins, and one-package
Stokes input are all generated from the fields below.
-/
structure NaturalCompactSupportExtDerivRouteMegaInput
    (I : ModelWithCorners Real (Fin (n + 1) -> Real) H)
    (omega : ManifoldForm I M n)
    (rho : SmoothPartitionOfUnity M I M univ)
    (ExtInteriorPiece : Type ei)
    (ExtBoundaryPiece : Type eb)
    (BoundaryPiece : Type b)
    (mu : Measure (Fin (n + 1) -> Real))
    [IsFiniteMeasureOnCompacts mu]
    [IsManifold I 1 M] where
  /-- Shared compact-support and unified-boundary data. -/
  base : NaturalCompactSupportRouteMegaBase I omega rho BoundaryPiece mu
  /-- Synchronized exterior-derivative constructor route. -/
  route :
    base.common.ExtDerivConstructorRoute
      (ExtInteriorPiece := ExtInteriorPiece)
      (ExtBoundaryPiece := ExtBoundaryPiece)
  /-- Equality between natural localized pieces and the route-localized M8 pieces. -/
  localizedPieces :
    NaturalFiniteActiveLocalizedPieceEqData
      base.chartBoxes
      (((base.common.toBoundaryMeasureInputOfExtDerivConstructorRoute
            (ExtInteriorPiece := ExtInteriorPiece)
            (ExtBoundaryPiece := ExtBoundaryPiece)
            route)
          |>.toSelectedReconstructionEndpointSource)
        |>.localized)
  /-- Chart-box containment that generates selected strict margins. -/
  containment :
    ((base.common.toBoundaryMeasureInputOfExtDerivConstructorRoute
        (ExtInteriorPiece := ExtInteriorPiece)
        (ExtBoundaryPiece := ExtBoundaryPiece)
        route)
      |>.StrictAlignmentChartBoxContainmentData)

