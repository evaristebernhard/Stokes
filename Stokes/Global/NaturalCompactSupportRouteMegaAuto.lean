import Stokes.Global.OnePackageRouteFromLocalizedPiecesAuto
import Stokes.Global.CompactSourceStrictContainmentRouteAuto
import Stokes.Global.BoundaryCanonicalRouteFromUnifiedSupportFiniteAuto

/-!
# Mega route for natural compact-support Stokes

This module is a theorem-facing composition layer for the current natural
compact-support route.

The input shape is intentionally close to the mathematical data now left on the
critical path:

* a compactly supported smooth form;
* compact-source finite-active chart-box data;
* unified boundary data, used both as `NaturalBulkEndpointCommonData` and as a
  support-finite canonical boundary route;
* a synchronized bulk route, either through the exterior-derivative constructor
  or through reconstruction;
* localized-piece equalities and chart-box containment, which generate the
  remaining chart alignment and strict margins.

No new analytic or geometric hypothesis is invented here.  Every theorem below
is obtained by routing the existing API through these larger packages.
-/

noncomputable section

set_option linter.style.longLine false
set_option linter.unusedSectionVars false

open Set MeasureTheory
open scoped BigOperators Manifold Topology

namespace Stokes

section NaturalCompactSupportRouteMegaAuto

universe u w b ei eb

variable {H : Type u} [TopologicalSpace H]
variable {M : Type w} [TopologicalSpace M] [ChartedSpace H M]
variable {BoundaryPiece : Type b}
variable {ExtInteriorPiece : Type ei} {ExtBoundaryPiece : Type eb}
variable {n : Nat}
variable {I : ModelWithCorners Real (Fin (n + 1) -> Real) H}
variable {omega : ManifoldForm I M n}
variable {rho : SmoothPartitionOfUnity M I M univ}
variable {mu : Measure (Fin (n + 1) -> Real)}
variable [IsFiniteMeasureOnCompacts mu]
variable [IsManifold I 1 M]

/--
Common compact-support route data shared by the ext-deriv and reconstruction
mega inputs.

`unified` is the endpoint-facing unified boundary package; it projects to
`NaturalBulkEndpointCommonData` for the synchronized bulk route.  The additional
`supportFinite` field records the stronger support-finite boundary route facts
over the same unified project-local boundary data.
-/
structure NaturalCompactSupportRouteMegaBase
    (I : ModelWithCorners Real (Fin (n + 1) -> Real) H)
    (omega : ManifoldForm I M n)
    (rho : SmoothPartitionOfUnity M I M univ)
    (BoundaryPiece : Type b)
    (mu : Measure (Fin (n + 1) -> Real))
    [IsFiniteMeasureOnCompacts mu]
    [IsManifold I 1 M] where
  /-- Compactly supported smooth form data. -/
  formData : CompactlySupportedSmoothFormData I omega
  /-- Compact support, finite active charts, and selected chart boxes. -/
  compactSource :
    CompactlySupportedSmoothFormData.NaturalFiniteActiveFromCompactSupportData
      (I := I) (omega := omega) (rho := rho) formData
  /-- Unified boundary package over the selected partition generated above. -/
  unified :
    NaturalBulkEndpointUnifiedInput
      (I := I) (omega := omega) (rho := rho)
      compactSource.toNaturalFiniteActiveChartBoxSelectionData
      BoundaryPiece mu
  /-- Support-finite boundary reconstruction facts for the same unified route. -/
  supportFinite :
    ProjectLocalBoundarySupportFiniteMeasureFacts
      unified.boundaryUnified.toProjectLocalGlobalStokesData

namespace NaturalCompactSupportRouteMegaBase

variable
    (B :
      NaturalCompactSupportRouteMegaBase
        I omega rho BoundaryPiece mu)

/-- The finite-active chart-box package generated by the compact source. -/
abbrev chartBoxes : NaturalFiniteActiveChartBoxSelectionData I omega rho :=
  B.compactSource.toNaturalFiniteActiveChartBoxSelectionData

/-- The selected partition generated by the compact-source data. -/
abbrev selectedPartition : SelectedBoxPartitionOfUnity I omega :=
  B.chartBoxes.selectedPartition

/-- The oriented boundary atlas carried by the unified input. -/
abbrev orientedBoundaryAtlas : BoundaryChartOrientedAtlas I M :=
  B.unified.orientedBoundaryAtlas

/-- The unified boundary source package carried by the base input. -/
abbrev boundaryUnified :
    BoundarySourceAlignmentUnifiedData
      (I := I) (omega := omega)
      (selectedPartition := B.selectedPartition)
      (orientedBoundaryAtlas := B.orientedBoundaryAtlas)
      (BoundaryPiece := BoundaryPiece) :=
  B.unified.boundaryUnified

/-- The endpoint common data consumed by synchronized bulk routes. -/
def common :
    NaturalBulkEndpointCommonData
      (I := I) (omega := omega) (rho := rho)
      B.chartBoxes BoundaryPiece mu :=
  B.unified.toCommonData

/-- Localized interior M8 data carried by the unified endpoint input. -/
abbrev localized :
    LocalizedInteriorM8Fields I omega B.selectedPartition :=
  B.unified.localized

/-- Boundary face-continuity facts carried by the unified endpoint input. -/
abbrev boundaryFaceContinuity :
    ProjectLocalBoundaryCanonicalFaceContinuityData
      B.boundaryUnified.toProjectLocalGlobalStokesData :=
  B.unified.boundaryFaceContinuity

/-- Boundary chart-change data carried by the unified endpoint input. -/
abbrev boundaryChartChange :
    BoundaryChartChangeSelectedFamilyData
      B.boundaryUnified.toProjectLocalGlobalStokesData :=
  B.unified.boundaryChartChange

/-- Support-finite canonical boundary route data over the same unified package. -/
def supportFiniteRouteData :
    BoundarySourceAlignmentUnifiedData.BoundaryCanonicalRouteFromUnifiedSupportFiniteData
      B.boundaryUnified where
  supportFinite := B.supportFinite
  faceContinuity := B.boundaryFaceContinuity

/-- Natural support-finite controlled-target input for the boundary side. -/
def boundaryNaturalSupportFiniteInput :
    BoundaryCanonicalTargetNaturalSupportFiniteInput
      B.boundaryUnified.toM8BoundaryControlledTargetInput
      B.boundaryUnified.toProjectLocalGlobalStokesData :=
  B.supportFiniteRouteData.toNaturalSupportFiniteInput

/-- Canonical boundary route generated by the support-finite unified data. -/
def boundaryCanonicalRouteMeasureInput :
    BoundaryCanonicalRouteMeasureInput
      B.boundaryUnified.toM8BoundaryControlledTargetInput.toM8TargetImageInput
      B.boundaryUnified.toProjectLocalGlobalStokesData :=
  B.supportFiniteRouteData.toBoundaryCanonicalRouteMeasureInput

/-- Global-measure view of the same canonical boundary route. -/
def globalBoundaryCanonicalRouteMeasureInput :
    BoundaryCanonicalRouteMeasureInput
      B.boundaryUnified.toM8BoundaryControlledTargetInput.toM8TargetImageInput
      B.boundaryUnified.toProjectLocalGlobalStokesData :=
  B.supportFiniteRouteData.toGlobalBoundaryCanonicalRouteMeasureInput

/-- Compact-support canonical boundary target package generated by the base input. -/
def canonicalBoundaryTargetCompactSupportInput :
    CanonicalBoundaryTargetCompactSupportInput
      (α := Fin n -> Real)
      B.boundaryUnified.toM8BoundaryControlledTargetInput.toM8TargetImageInput
      (volume : Measure (Fin n -> Real)) :=
  B.supportFiniteRouteData.toCanonicalBoundaryTargetCompactSupportInput

/-- Boundary-only M8 measure data generated by the support-finite route. -/
def m8BoundaryMeasureData :
    M8BoundaryMeasureData I omega B.selectedPartition
      B.boundaryUnified.toM8BoundaryControlledTargetInput.toM8TargetImageInput.targetImages :=
  B.supportFiniteRouteData.toM8BoundaryMeasureData

