/-- The proposition shape produced by a compact-carrier extension theorem. -/
def ExistsChartwiseSingularCubeCompactExtensionInput {n m : Nat}
    {I : ModelWithCorners Real (Fin m → Real) H}
    (omega : ManifoldForm I M n)
    (chart : M) (cube : SmoothSingularCube (n + 1) m) : Prop :=
  ∃ _E : ChartwiseSingularCubeCompactExtensionInput omega chart cube, True

/-- Boundary-integral facade using compact-carrier extension input. -/
theorem chartwise_singular_boundary_stokes_of_compactExtensionInput {n m : Nat}
    {I : ModelWithCorners Real (Fin m → Real) H}
    {omega : ManifoldForm I M n}
    (chart : M) (cube : SmoothSingularCube (n + 1) m)
    (E : ChartwiseSingularCubeCompactExtensionInput omega chart cube) :
    SingularCubeStokes.bdryIntegral_singular cube (chartLocalForm I chart omega) =
      integrateForm cube (fun y => extDeriv (chartLocalForm I chart omega) y) :=
  E.boundary_stokes

/-- Chain-level facade using compact-carrier extension input. -/
theorem chartwise_singular_chain_stokes_of_compactExtensionInput {n m : Nat}
    {I : ModelWithCorners Real (Fin m → Real) H}
    {omega : ManifoldForm I M n}
    (chart : M) (cube : SmoothSingularCube (n + 1) m)
    (E : ChartwiseSingularCubeCompactExtensionInput omega chart cube) :
    integrateChain (singularBoundarySingle cube) (chartLocalForm I chart omega) =
      integrateForm cube (fun y => extDeriv (chartLocalForm I chart omega) y) :=
  E.chain_stokes

/-- Boundary-integral facade from the compact-carrier existential output. -/
theorem chartwise_singular_boundary_stokes_of_exists_compactExtensionInput {n m : Nat}
    {I : ModelWithCorners Real (Fin m → Real) H}
    {omega : ManifoldForm I M n}
    (chart : M) (cube : SmoothSingularCube (n + 1) m)
    (hE : ExistsChartwiseSingularCubeCompactExtensionInput omega chart cube) :
    SingularCubeStokes.bdryIntegral_singular cube (chartLocalForm I chart omega) =
      integrateForm cube (fun y => extDeriv (chartLocalForm I chart omega) y) := by
  rcases hE with ⟨E, _⟩
  exact chartwise_singular_boundary_stokes_of_compactExtensionInput chart cube E

/-- Chain-level facade from the compact-carrier existential output. -/
theorem chartwise_singular_chain_stokes_of_exists_compactExtensionInput {n m : Nat}
    {I : ModelWithCorners Real (Fin m → Real) H}
    {omega : ManifoldForm I M n}
    (chart : M) (cube : SmoothSingularCube (n + 1) m)
    (hE : ExistsChartwiseSingularCubeCompactExtensionInput omega chart cube) :
    integrateChain (singularBoundarySingle cube) (chartLocalForm I chart omega) =
      integrateForm cube (fun y => extDeriv (chartLocalForm I chart omega) y) := by
  rcases hE with ⟨E, _⟩
  exact chartwise_singular_chain_stokes_of_compactExtensionInput chart cube E

/-- A compact-carrier extension input supplies the existing open-input shape. -/
theorem exists_openExtensionInput_of_exists_compactExtensionInput {n m : Nat}
    {I : ModelWithCorners Real (Fin m → Real) H}
    {omega : ManifoldForm I M n}
    {chart : M} {cube : SmoothSingularCube (n + 1) m}
    (hE : ExistsChartwiseSingularCubeCompactExtensionInput omega chart cube) :
    ExistsChartwiseSingularCubeOpenExtensionInput omega chart cube := by
  rcases hE with ⟨E, _⟩
  exact E.exists_openExtensionInput

